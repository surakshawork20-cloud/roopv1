# ─── Supabase (required) ────────────────────────────────────────
# Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."     # secret, server-only

# Gate for POST /api/seed (any random string; used once after deploy)
SEED_SECRET="change-this"

# ─── Email notifications (optional — Resend) ────────────────────
# Without these, notifications log to console and skip sending.
# https://resend.com → create API key, verify sending domain.
RESEND_API_KEY=""
RESEND_FROM="Roop <bookings@your-verified-domain.com>"

# ─── Payments (optional — Razorpay) ─────────────────────────────
# Without these, the Payments tab shows "Payments not configured on server"
# when artists try to pay. Frontend still renders.
# Dashboard → Settings → API Keys (use live keys for prod, test keys for dev)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
